{
  "name": "fwd.moe",
  "description": "A simple preact app for path-based fwds (forwards/redirects), stored via local storage.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:github-pages": "npm run build && ncp dist/index.html dist/404.html",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "preact": "^10.29.3",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.3.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ncp": "^2.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": "npm run lint"
  }
}
